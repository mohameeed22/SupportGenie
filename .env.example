# ─────────────────────────────────────────────
#  NovaBuy Support Bot — Environment Variables
# ─────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Groq AI ────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use — recommended: llama-3.3-70b-versatile
# Other fast options: llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── Support Settings ───────────────────────
SUPPORT_EMAIL=support@novabuy.store
SUPPORT_HOURS=Monday-Friday, 9am-6pm EST

# ── Admin Configuration ────────────────────
# Comma-separated list of Telegram user IDs for admin commands
# Get your ID by sending /whoami to BotFather
ADMIN_USER_IDS=123456789,987654321

# ── Rate Limiting ──────────────────────────
# Prevent abuse: max messages per user per window
RATE_LIMIT_MAX_MESSAGES=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── Database ───────────────────────────────
# Path to SQLite database (relative to bot root)
# Default: supportgenie.db
# For Docker: /data/supportgenie.db (volume mount)
SUPPORTGENIE_DB_PATH=supportgenie.db
