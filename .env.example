# ─────────────────────────────────────────────
#  NovaBuy Support Bot — Environment Variables
# ─────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Groq AI ────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Support Settings ───────────────────────
SUPPORT_EMAIL=support@novabuy.store
SUPPORT_HOURS=Monday-Friday, 9am-6pm EST

# Telegram group chat ID for live agent handoff (negative number for groups)
# Create a private group, add your bot as admin, get the chat ID
SUPPORT_GROUP_CHAT_ID=

# ── Admin Configuration ────────────────────
# Comma-separated list of Telegram user IDs for admin commands
ADMIN_USER_IDS=123456789,987654321

# ── Rate Limiting ──────────────────────────
# Base rate limit for all users
RATE_LIMIT_MAX_MESSAGES=10
RATE_LIMIT_WINDOW_SECONDS=60

# Tiered rate limits (JSON): known customers get higher limits
# {"known": {"max": 30, "window": 60}, "anonymous": {"max": 5, "window": 60}}
RATE_LIMIT_TIERS={"known":{"max":30,"window":60},"anonymous":{"max":5,"window":60}}

# ── Database ───────────────────────────────
SUPPORTGENIE_DB_PATH=supportgenie.db

# ── Redis (optional) ───────────────────────
# Enables caching for order lookups, rate limiting, and session storage
REDIS_URL=

# ── RAG Configuration ──────────────────────
# Enable semantic search over products & policies
RAG_ENABLED=true
RAG_TOP_K=3

# ── Webhook Mode (instead of polling) ─────
# Set WEBHOOK_URL to enable webhook mode (e.g., https://yourdomain.com/webhook)
WEBHOOK_URL=
WEBHOOK_PORT=8443

# ── Scheduled Notifications ────────────────
# Job queue interval in minutes for checking order updates
NOTIFICATION_CHECK_INTERVAL=30

# ── CSAT Surveys ──────────────────────────
CSAT_ENABLED=true
